rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function getUserData() { 
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return userDoc != null ? userDoc.data : null;
    }
    
    function isSameEmpresa(empresaIdCheck) { 
      let u = getUserData(); 
      return u != null && String(u.empresaId) == String(empresaIdCheck); 
    }
    
    function isOwnerAdmin() { let u = getUserData(); return u != null && (u.role == 'admin' || u.role == 'proprietario'); }
    function isStaff() { let u = getUserData(); return u != null && (u.role == 'admin' || u.role == 'proprietario' || u.role == 'recepcionista'); }

    // Helper to check if resource or request belongs to user's empresa
    function belongsToEmpresa(data) {
      let u = getUserData();
      return u != null && String(u.empresaId) == String(data.empresaId);
    }

    match /usuarios/{userId} {
      allow read, write: if isSignedIn(); // Needs better control later
    }

    match /clientes/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data);
    }
    match /agendamentos/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data);
    }
    match /notificacoes/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data);
    }

    match /profissionais/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isOwnerAdmin();
    }
    match /servicos/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isOwnerAdmin();
    }
    
    match /configuracoes/{id} { 
      allow read, write: if isSignedIn() && isSameEmpresa(id); 
    }

    match /produtos/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isStaff();
    }
    match /movimentacoes/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isStaff();
    }
    match /caixa_transacoes/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isStaff();
    }
    match /caixa_status/{id} { 
      allow read, write: if isSignedIn() && isSameEmpresa(id) && isStaff();
    }
    match /contas_receber/{id} { 
      allow read, write: if isSignedIn() && belongsToEmpresa(resource != null ? resource.data : request.resource.data) && isStaff();
    }
  }
}
